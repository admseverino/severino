# Database (same URL used by `packages/db` migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hidrosync-service

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Until a user with role system_admin exists, /login shows "Primeiro acesso" to create the
# superadmin in the UI. After that, only "Entrar" is shown.

# Google OAuth (optional — leave empty to hide the Google button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: force SSL for remote Postgres
# DATABASE_SSL=true

# Playwright (`pnpm test:e2e`) — user must exist in DATABASE_URL with this password
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=
