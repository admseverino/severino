# Used by `pnpm run db:migrate` / `pnpm run db:generate` (packages/db).
# Copy to `.env` in this directory (repo root):
#   cp .env.example .env

# DB for migrations / create-superadmin. If `hidrosync-service/.env` sets DATABASE_URL, that
# value wins for `pnpm create-superadmin` (same DB as Next.js).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hidrosync-service

# Optional: set to `true` for managed Postgres that requires TLS (non-localhost).
# DATABASE_SSL=true

# Used by `hidrosync-service` script `pnpm --filter hidrosync-service run create-superadmin`
# and by `node scripts/create-superadmin.js` (e.g. after Cloud Build db:check).
# Preferred names (also accepted: superadminuser / superadminpass):
 SUPERADMIN_USER=admin@example.com
 SUPERADMIN_PASS=change-me