{
    "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
    "theme": "tribe",
    "active": "default",
    "activateOnStartup": true,
    "noClear": false,
    "keepExistingTerminals": false,
    "sessions": {
        "default": [
            {
                "name": "gcloud auth",
                "autoExecuteCommands": false,
                "icon": "person",
                "color": "terminal.ansiGreen",
                "commands": [
                    "gcloud auth login"
                ]
            },
            [
                {
                    "name": "all-services (turbo)",
                    "autoExecuteCommands": false,
                    "icon": "play-circle",
                    "color": "terminal.ansiCyan",
                    "commands": [
                        "pnpm run dev --continue"
                    ]
                }
            ],
            [
                {
                    "name": "option-service",
                    "autoExecuteCommands": false,
                    "icon": "home",
                    "commands": [
                        "pnpm --filter option-service run dev"
                    ]
                },
                {
                    "name": "dash-service",
                    "autoExecuteCommands": false,
                    "icon": "server",
                    "commands": [
                        "pnpm --filter dash-service run dev"
                    ]
                }
            ],
            [
                {
                    "name": "scraping-function",
                    "autoExecuteCommands": false,
                    "icon": "gear",
                    "commands": [
                        "pnpm --filter scraping-function run dev"
                    ]
                },
                {
                    "name": "surface-sync-function",
                    "autoExecuteCommands": false,
                    "icon": "gear",
                    "commands": [
                        "pnpm --filter surface-sync-function run dev"
                    ]
                }
            ],
            [
                {
                    "name": "scraping-job",
                    "autoExecuteCommands": false,
                    "icon": "zap",
                    "commands": [
                        "pnpm --filter scraping-job scrape:dev"
                    ]
                }
            ],
            [
                {
                    "name": "test option-service",
                    "autoExecuteCommands": false,
                    "icon": "beaker",
                    "commands": [
                        "pnpm --filter option-service run typecheck:e2e && pnpm --filter option-service run test:e2e"
                    ]
                },
                {
                    "name": "test option-dash",
                    "autoExecuteCommands": false,
                    "icon": "beaker",
                    "commands": [
                        "pnpm --filter dash-service run test:e2e"
                    ]
                }
            ],
            [
                {
                    "name": "git",
                    "icon": "git-commit",
                    "autoExecuteCommands": false,
                    "commands": [
                        "git "
                    ]
                }
            ]
        ],
        "saved-session": [
            {
                "name": "connect",
                "autoExecuteCommands": false,
                "commands": [
                    ""
                ]
            }
        ]
    }
}