{
  "task.allowAutomaticTasks": "on",
  "terminal.integrated.defaultProfile.osx": "severino zsh",
  "terminal.integrated.defaultProfile.linux": "severino bash",
  "terminal.integrated.automationProfile.osx": {
    "path": "/bin/zsh",
    "args": ["-il"],
    "env": {
      "ZDOTDIR": "${workspaceFolder}/.vscode"
    }
  },
  "terminal.integrated.automationProfile.linux": {
    "path": "/bin/bash",
    "args": [
      "--rcfile",
      "${workspaceFolder}/.vscode/project_aliases",
      "-i"
    ]
  },
  "terminal.integrated.profiles.osx": {
    "severino zsh": {
      "path": "/bin/zsh",
      "args": ["-il"],
      "env": {
        "ZDOTDIR": "${workspaceFolder}/.vscode"
      }
    }
  },
  "terminal.integrated.profiles.linux": {
    "severino bash": {
      "path": "/bin/bash",
      "args": [
        "--rcfile",
        "${workspaceFolder}/.vscode/project_aliases",
        "-i"
      ]
    }
  }
}
