# Copy to severino-webhook/.env for local runs (no Docker):
#   cp severino-webhook/env.example severino-webhook/.env
# DATABASE_URL can live in the repo root .env — dev scripts load both via --env-file.
NODE_ENV=development
PORT=8080
SERVICE_ROLE=ingest

# Meta / WhatsApp
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=

# Pub/Sub (ingest publishes; worker receives push)
GCP_PROJECT_ID=your-gcp-project
PUBSUB_TOPIC=whatsapp-events
# direct = POST to worker locally; pubsub = @google-cloud/pubsub (default in production)
PUBLISHER_MODE=direct
WORKER_URL=http://127.0.0.1:8081

# Worker only — OIDC audience for Pub/Sub push (set to worker service URL in prod)
PUBSUB_PUSH_AUDIENCE=

# Database (@severino/db) — required for ingest + worker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/severino-service
