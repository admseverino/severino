# Copy to severino-webhook/.env for local runs (no Docker):
#   cp severino-webhook/env.example severino-webhook/.env
# DATABASE_URL can live in the repo root .env — dev scripts load both via --env-file.
NODE_ENV=development
# Default when `run-dev.sh` is invoked without ingest|worker (prefer dev:ingest / dev:worker).
PORT=8080
SERVICE_ROLE=ingest
# Per-role overrides (run-dev.sh sets these for dev:ingest / dev:worker)
# INGEST_PORT=8080
# WORKER_PORT=8081

# Meta / WhatsApp
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=

# Pub/Sub (ingest publishes; worker receives push)
GCP_PROJECT_ID=severino-project
PUBSUB_TOPIC=whatsapp-events
# Second push subscription for live dev mirror (scripts/dev-mirror-sub.sh on|off)
PUBSUB_LOCAL_SUBSCRIPTION=whatsapp-events-push-local
PUBSUB_DLQ_TOPIC=whatsapp-events-dlq
# direct = POST to worker locally; pubsub = @google-cloud/pubsub (default in production)
PUBLISHER_MODE=direct
WORKER_URL=http://127.0.0.1:8081

# Worker only — OIDC audience for Pub/Sub push (prod Cloud Run URL, or ngrok URL when mirroring)
PUBSUB_PUSH_AUDIENCE=
# ngrok HTTPS URL -> local worker :8081 (no trailing slash). Used by run-dev-stack.sh, dev-mirror-sub.sh, dev:worker.
WORKER_TUNNEL_URL=

# Database — local dev uses DATABASE_URL; Cloud Run uses the four vars below (set by cloudbuild).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/severino-service
# INSTANCE_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_PASS=
# DB_NAME=severino-service
