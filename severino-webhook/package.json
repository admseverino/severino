{
  "name": "severino-webhook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh scripts/run-dev-stack.sh",
    "dev:ingest": "sh scripts/run-dev.sh ingest",
    "dev:worker": "sh scripts/run-dev.sh worker",
    "ngrok": "sh scripts/run-ngrok.sh",
    "mirror:on": "sh scripts/dev-mirror-sub.sh on",
    "mirror:off": "sh scripts/dev-mirror-sub.sh off",
    "mirror:status": "sh scripts/dev-mirror-sub.sh status",
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/**/*.test.ts",
    "start": "sh scripts/run-prod.sh",
    "start:ingest": "sh scripts/run-prod.sh ingest",
    "start:worker": "sh scripts/run-prod.sh worker",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.11.0",
    "@severino/db": "workspace:*",
    "@severino/phone": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.57.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
