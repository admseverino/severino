{
  "name": "severino-webhook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh scripts/run-dev.sh",
    "dev:ingest": "sh scripts/run-dev.sh ingest",
    "dev:worker": "sh scripts/run-dev.sh worker",
    "build": "tsc -p tsconfig.json",
    "start": "sh scripts/run-prod.sh",
    "start:ingest": "sh scripts/run-prod.sh ingest",
    "start:worker": "sh scripts/run-prod.sh worker",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^4.11.0",
    "@severino/db": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
