# Database (same URL used by `packages/db` migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hidrosync-service

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Until a user with role system_admin exists, /login shows "Primeiro acesso" to create the
# superadmin in the UI. After that, only "Entrar" is shown.

# Google OAuth (optional — leave empty to hide the Google button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: force SSL for remote Postgres
# DATABASE_SSL=true

# Playwright (`pnpm test:e2e`) — user must exist in DATABASE_URL with this password
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=

# Phone verification via WhatsApp QR (defaults to +5551995969303 when unset)
# WHATSAPP_VERIFICATION_PHONE_E164=+5551995969303
# Optional: send verification code directly to the user's WhatsApp number
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# --- Onboarding prompt → structure extractor (M1) ---------------------------
# Pick the LLM provider: `mock` (deterministic, no API call), `openai`, `openrouter`.
# When unset, auto-detects: OpenAI if its key is set, then OpenRouter, then mock.
# Force `mock` in CI to keep Playwright assertions deterministic.
# ONBOARDING_LLM_PROVIDER=openai
# Optional: onboarding chat request timeout (ms), default 25000, max 600000. Raise for slow models.
# ONBOARDING_LLM_TIMEOUT_MS=90000

# OpenAI (chat completions). Required if ONBOARDING_LLM_PROVIDER=openai.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# OpenRouter (chat completions). Required if ONBOARDING_LLM_PROVIDER=openrouter.
# OPENROUTER_API_KEY=
# OPENROUTER_ONBOARDING_MODEL=google/gemini-2.5-flash
# OPENROUTER_SITE_URL=https://severi.no
# OPENROUTER_APP_NAME=Severino
